# =====================================================================
#  Server Node (user panel) — environment configuration
#  Copy to .env on your aaPanel host. NEVER commit the real .env.
# =====================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- Master connection ---------------------------------------------
# The Master server this Node forwards all operations to.
MASTER_URL=https://master.example.com
MASTER_TIMEOUT_MS=20000

# ---- License credentials (issued by the Master at registration) -----
# Shown ONCE during registration — store them only here.
LICENSE_KEY=00000000-0000-0000-0000-000000000000
LICENSE_SECRET=CHANGE_ME_license_secret

# ---- Local panel session -------------------------------------------
# Signs the panel's session cookie. Generate: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_session_secret
SESSION_COOKIE=node_sid
SESSION_TTL_HOURS=24

# ---- Offline tolerance ---------------------------------------------
# How long the cached license stays usable if the Master is unreachable.
OFFLINE_TOLERANCE_HOURS=24
