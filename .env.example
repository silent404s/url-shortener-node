# =====================================================================
#  Server Node (user panel) — environment configuration
#  Copy to .env on your aaPanel host. NEVER commit the real .env.
# =====================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- Master connection ---------------------------------------------
# The Master server this Node forwards all operations to.
MASTER_URL=https://machdientu.de.com
MASTER_TIMEOUT_MS=20000

# ---- License credentials (OPTIONAL) ---------------------------------
# You can leave these blank and configure the license via the web wizard at
# /setup (it writes to data/config.json). If set here, env wins.
LICENSE_KEY=
LICENSE_SECRET=

# ---- Local panel session -------------------------------------------
# Signs the panel's session cookie. Generate: openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_session_secret
SESSION_COOKIE=node_sid
SESSION_TTL_HOURS=8
SESSION_IDLE_MINUTES=30

# Secret login path (deters drive-by access). Use something unguessable.
# Example: /masuk-7f3a9c21 . Defaults to /login if unset.
LOGIN_PATH=/login

# ---- OTA "Update Situs" (pull latest code + restart from the panel) --
# PM2 process name to restart, and the app directory. The installer sets these.
PM2_NAME=node-panel
APP_DIR=
OTA_ENABLED=true

# ---- Offline tolerance ---------------------------------------------
# How long the cached license stays usable if the Master is unreachable.
OFFLINE_TOLERANCE_HOURS=24
