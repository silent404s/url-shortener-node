<%- include('partials/head', { title: 'Masuk · Shortix' }) %>
<main class="auth-wrap">
  <div class="card auth-card">
    <div class="auth-brand"><i class="fa-solid fa-bolt"></i> Shortix</div>
    <h1>Masuk ke Panel</h1>
    <p class="muted">Panel ini terhubung dengan lisensi yang dikeluarkan server Master.
      Klik tombol di bawah untuk memvalidasi lisensi dan masuk.</p>
    <button id="loginBtn" class="btn primary block">
      <i class="fa-solid fa-right-to-bracket"></i> Validasi lisensi &amp; masuk
    </button>
    <p id="loginMsg" class="msg"></p>
    <p class="muted small">
      Butuh bantuan? Lihat <a href="/agreement">Ketentuan Layanan</a>.
    </p>
  </div>
</main>
<script src="/static/js/login.js"></script>
</body>
</html>
